# ── Uygulama ────────────────────────────────────────────────────────────────
APP_NAME="Rose Garden Çiçek Çikolata"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Istanbul
APP_URL=http://localhost
# Canlı: APP_URL=https://rosegardencicekcilik.com.tr (alan adı; www kullanıyorsanız tek biçimde sabitleyin)

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ── Loglama ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Sentry Error Tracking
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# ── Veritabanı ───────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rose_garden
DB_USERNAME=root
DB_PASSWORD=

# ── Oturum & Önbellek ─────────────────────────────────────────────────────────
# Yerelde varsayılan config/session.php: file (DB gerekmez). Prod’da çok sunucu yoksa file yeterli; cluster için database kullanın.
SESSION_DRIVER=file
SESSION_LIFETIME=120
# ── Oturum güvenliği (production: SESSION_SECURE_COOKIE=true; local + http için false kalmalı — aksi halde Filament 419) ──────────────
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
SCHEDULE_CACHE_STORE=file
CACHE_PREFIX=rg_

# ── Proxy (Cloudflare / load balancer) ───────────────────────────────────────
# Production/staging behind TLS termination: set to * or real proxy IPs (see Cloudflare IP ranges).
# Local (APP_ENV=local): leave unset or empty — wildcard here can cause Filament 419 on http://.
# TRUSTED_PROXIES=

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Posta ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="info@rosegardencicekcilik.com.tr"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS (isteğe bağlı) ────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── PayTR Ödeme Entegrasyonu ─────────────────────────────────────────────────
# Admin panelden girilen değerler bu .env değerlerini override eder
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=true
PAYTR_DEBUG=false
PAYTR_TIMEOUT=30
PAYTR_API_URL=https://www.paytr.com/odeme/api/get-token
PAYTR_IFRAME_URL=https://www.paytr.com/odeme/guvenli/
PAYTR_SUCCESS_URL=/odeme/basarili
PAYTR_FAIL_URL=/odeme/basarisiz
PAYTR_CALLBACK_URL=/api/paytr/callback
PAYTR_ALLOWED_IPS=193.140.143.0/24

# ── SMS Entegrasyonu ─────────────────────────────────────────────────────────
SMS_API_URL=
SMS_USERNAME=
SMS_PASSWORD=
SMS_SUBSCRIBER_NO=
SMS_SENDER_TITLE=ROSEGARDEN
SMS_ENABLED=false

# ── Google OAuth & Maps ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=/auth/google/callback
GOOGLE_MAPS_KEY=

# ── Google Translate ─────────────────────────────────────────────────────────
GOOGLE_TRANSLATE_API_KEY=

# ── Google Analytics (GA4 ölçüm kimliği) ─────────────────────────────────────
GOOGLE_ANALYTICS_ID=G-WRTKSNRSBR
